# Default: detect text vs binary automatically.
* text=auto eol=lf

# Shell scripts MUST be LF on disk to run on Linux/macOS.
*.sh text eol=lf

# Windows batch + PowerShell prefer CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Binary assets — never alter line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pptx binary
*.pdf binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
