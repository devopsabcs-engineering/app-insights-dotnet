@page
@using Microsoft.AspNetCore.Mvc.Localization
@model Mapaq.Web.Pages.Etablissements.IndexModel
@inject IHtmlLocalizer<Mapaq.Web.SharedResource> L
@{
    ViewData["Title"] = L["Search.Title"].Value;
    var attempted = !string.IsNullOrWhiteSpace(Model.City) || !string.IsNullOrWhiteSpace(Model.Region);
}

<h1>@L["Search.Heading"]</h1>

<form method="get" class="search-form">
    <div class="field">
        <label for="city">@L["Search.Field.City"]</label>
        <input id="city" name="city" value="@Model.City" placeholder="@L["Search.Field.City.Placeholder"]" />
    </div>
    <div class="field">
        <label for="region">@L["Search.Field.Region"]</label>
        <select id="region" name="region">
            <option value="">@L["Search.Field.Region.AnyRegion"]</option>
            @foreach (var r in Model.AvailableRegions)
            {
                <option value="@r" selected="@(r == Model.Region)">@r</option>
            }
        </select>
    </div>
    <div class="field" style="flex: 0 0 auto;">
        <label>&nbsp;</label>
        <button type="submit" class="btn">@L["Search.Button"]</button>
    </div>
</form>

@if (!attempted)
{
    <div class="empty-state">@L["Search.PromptInitial"]</div>
}
else if (Model.Results.Count == 0)
{
    <div class="empty-state">@L["Search.NoResults"]</div>
}
else
{
    <p class="muted mb-2">@string.Format(L["Search.ResultsLabel"].Value, Model.Results.Count)</p>
    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Search.Col.Name"]</th>
                <th>@L["Search.Col.Address"]</th>
                <th>@L["Search.Col.City"]</th>
                <th>@L["Search.Col.Region"]</th>
                <th class="text-right">@L["Search.Col.Action"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Results)
            {
                <tr>
                    <td><strong>@e.Name</strong></td>
                    <td>@e.Address</td>
                    <td>@e.City</td>
                    <td><span class="badge badge--sky">@e.Region</span></td>
                    <td class="text-right">
                        <a class="btn btn--ghost" asp-page="/Etablissements/Detail" asp-route-id="@e.EstablishmentId">@L["Search.View"]</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
