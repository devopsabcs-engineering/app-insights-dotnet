@page "{id:long}"
@using Microsoft.AspNetCore.Mvc.Localization
@using System.Globalization
@model Mapaq.Web.Pages.Etablissements.DetailModel
@inject IHtmlLocalizer<Mapaq.Web.Resources.SharedResource> L
@{
    var isFr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    ViewData["Title"] = L["Detail.Title"].Value;
}

<p><a asp-page="/Etablissements/Index">@L["Detail.BackToSearch"]</a></p>

@if (Model.Establishment is null)
{
    <div class="empty-state">@L["Detail.NotFound"]</div>
}
else
{
    var e = Model.Establishment;
    <section class="hero">
        <h1>@e.Name</h1>
        <p>@e.Address · @e.City <span class="badge badge--sky">@e.Region</span></p>
    </section>

    <h2>@L["Detail.Convictions"]</h2>
    @if (e.Convictions.Count == 0)
    {
        <div class="empty-state">@L["Detail.NoConvictions"]</div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>@L["Detail.Col.Date"]</th>
                    <th>@L["Detail.Col.Article"]</th>
                    <th>@L["Detail.Col.Description"]</th>
                    <th class="num">@L["Detail.Col.Fine"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in e.Convictions)
                {
                    <tr>
                        <td>@c.ConvictionDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge">@c.ArticleCode</span></td>
                        <td>@(isFr ? c.ArticleTitleFr : c.ArticleTitleEn)</td>
                        <td class="num">@c.AmountCad.ToString("N2", CultureInfo.CurrentUICulture)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
