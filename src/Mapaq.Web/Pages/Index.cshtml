@page
@using Microsoft.AspNetCore.Mvc.Localization
@model Mapaq.Web.Pages.IndexModel
@inject IHtmlLocalizer<Mapaq.Web.SharedResource> L
@inject Microsoft.Extensions.Configuration.IConfiguration Cfg
@{
    ViewData["Title"] = L["Home.Title"].Value;
    var apiBase = (Cfg["MapaqApi:BaseAddress"] ?? "https://localhost:7020/").TrimEnd('/');
    var swaggerUrl = $"{apiBase}/swagger";
    var openApiUrl = $"{apiBase}/openapi/v1.json";
}

<h1>@L["Home.Heading"]</h1>
<p class="lede">@L["Home.Lede"]</p>

<div class="tag-pills">
    <a class="tag-pill" asp-page="/Etablissements/Index" asp-route-region="06-MONTREAL">@L["Tag.Montreal"]</a>
    <a class="tag-pill" asp-page="/Etablissements/Index" asp-route-region="03-CAPITALE-NATIONALE">@L["Tag.CapitaleNationale"]</a>
    <a class="tag-pill" asp-page="/Etablissements/Index" asp-route-region="16-MONTEREGIE">@L["Tag.Monteregie"]</a>
    <a class="tag-pill" asp-page="/Inspections/Rollup">@L["Tag.Rollup"]</a>
    <a class="tag-pill" asp-page="/Inspections/Rollup" asp-route-region="06-MONTREAL" asp-route-indicator="04-PermisSuspendus">@L["Tag.SuspendedPermits"]</a>
    <a class="tag-pill" asp-page="/Etablissements/Index" asp-route-region="07-OUTAOUAIS">@L["Tag.Outaouais"]</a>
    <a class="tag-pill" href="@swaggerUrl" target="_blank" rel="noopener">@L["Tag.SwaggerUi"]</a>
</div>

<div class="topic-grid">
    <section class="topic">
        <header class="topic__head">
            <span class="topic__icon" aria-hidden="true">🥬</span>
            <h3 class="topic__title">@L["Topic.Inspections.Title"]</h3>
        </header>
        <ul class="topic__links">
            <li><a asp-page="/Etablissements/Index">@L["Topic.Inspections.Link.Search"]</a></li>
            <li><a asp-page="/Etablissements/Index" asp-route-region="06-MONTREAL">@L["Topic.Inspections.Link.Montreal"]</a></li>
            <li><a asp-page="/Etablissements/Index" asp-route-region="03-CAPITALE-NATIONALE">@L["Topic.Inspections.Link.Quebec"]</a></li>
            <li><a asp-page="/Inspections/Rollup">@L["Topic.Inspections.Link.Indicators"]</a></li>
        </ul>
        <a class="topic__more" asp-page="/Etablissements/Index">@L["Topic.More"]</a>
    </section>

    <section class="topic">
        <header class="topic__head">
            <span class="topic__icon" aria-hidden="true">⚖️</span>
            <h3 class="topic__title">@L["Topic.Convictions.Title"]</h3>
        </header>
        <ul class="topic__links">
            <li><a asp-page="/Etablissements/Index" asp-route-region="06-MONTREAL">@L["Topic.Convictions.Link.RecentMontreal"]</a></li>
            <li><a asp-page="/Etablissements/Index" asp-route-region="16-MONTEREGIE">@L["Topic.Convictions.Link.Monteregie"]</a></li>
            <li><a asp-page="/Inspections/Rollup" asp-route-indicator="03-AmendesEmises">@L["Topic.Convictions.Link.Fines"]</a></li>
            <li><a asp-page="/Inspections/Rollup" asp-route-indicator="02-AvisNonConformite">@L["Topic.Convictions.Link.Notices"]</a></li>
        </ul>
        <a class="topic__more" asp-page="/Etablissements/Index">@L["Topic.More"]</a>
    </section>

    <section class="topic">
        <header class="topic__head">
            <span class="topic__icon" aria-hidden="true">📊</span>
            <h3 class="topic__title">@L["Topic.Dashboard.Title"]</h3>
        </header>
        <ul class="topic__links">
            <li><a asp-page="/Inspections/Rollup">@L["Topic.Dashboard.Link.Region"]</a></li>
            <li><a asp-page="/Inspections/Rollup" asp-route-indicator="01-Inspections">@L["Topic.Dashboard.Link.Inspections"]</a></li>
            <li><a asp-page="/Inspections/Rollup" asp-route-indicator="04-PermisSuspendus">@L["Topic.Dashboard.Link.Suspended"]</a></li>
            <li><a asp-page="/Inspections/Rollup" asp-route-indicator="03-AmendesEmises">@L["Topic.Dashboard.Link.Fines"]</a></li>
        </ul>
        <a class="topic__more" asp-page="/Inspections/Rollup">@L["Topic.More"]</a>
    </section>

    <section class="topic">
        <header class="topic__head">
            <span class="topic__icon" aria-hidden="true">🛠</span>
            <h3 class="topic__title">@L["Topic.Api.Title"]</h3>
        </header>
        <ul class="topic__links">
            <li><a href="@swaggerUrl" target="_blank" rel="noopener">@L["Topic.Api.Link.Swagger"]</a></li>
            <li><a href="@openApiUrl" target="_blank" rel="noopener">@L["Topic.Api.Link.OpenApi"]</a></li>
            <li><a href="@apiBase/api/establishments?region=06-MONTREAL" target="_blank" rel="noopener">@L["Topic.Api.Link.SearchSample"]</a></li>
            <li><a href="@apiBase/api/inspections/rollup?region=06-MONTREAL&year=@DateTime.UtcNow.Year" target="_blank" rel="noopener">@L["Topic.Api.Link.RollupSample"]</a></li>
        </ul>
        <a class="topic__more" href="@swaggerUrl" target="_blank" rel="noopener">@L["Topic.Api.OpenSwagger"]</a>
    </section>

    <section class="topic">
        <header class="topic__head">
            <span class="topic__icon" aria-hidden="true">🛰</span>
            <h3 class="topic__title">@L["Topic.Trace.Title"]</h3>
        </header>
        <ul class="topic__links">
            <li>@L["Topic.Trace.Body"]</li>
        </ul>
        <a class="topic__more" href="https://learn.microsoft.com/azure/azure-monitor/app/app-map" target="_blank" rel="noopener">@L["Topic.Trace.LearnMore"]</a>
    </section>
</div>
