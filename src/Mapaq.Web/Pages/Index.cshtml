@page
@using Microsoft.AspNetCore.Mvc.Localization
@model Mapaq.Web.Pages.IndexModel
@inject IHtmlLocalizer<Mapaq.Web.Resources.SharedResource> L
@{
    ViewData["Title"] = L["Home.Title"].Value;
}

<section class="hero">
    <h1>@L["Home.Heading"]</h1>
    <p>@L["Home.Lede"]</p>
    <div class="flex">
        <a class="btn" asp-page="/Etablissements/Index">@L["Home.Tile.Search.Title"]</a>
        <a class="btn btn--ghost" asp-page="/Inspections/Rollup">@L["Home.Tile.Rollup.Title"]</a>
    </div>
</section>

<div class="tile-grid">
    <a class="tile tile--sky" asp-page="/Etablissements/Index">
        <span class="tile__icon">🔎</span>
        <h3>@L["Home.Tile.Search.Title"]</h3>
        <p>@L["Home.Tile.Search.Body"]</p>
    </a>
    <a class="tile tile--leaf" asp-page="/Inspections/Rollup">
        <span class="tile__icon">📊</span>
        <h3>@L["Home.Tile.Rollup.Title"]</h3>
        <p>@L["Home.Tile.Rollup.Body"]</p>
    </a>
    <div class="tile tile--orange">
        <span class="tile__icon">🛰</span>
        <h3>@L["Home.Tile.Trace.Title"]</h3>
        <p>@L["Home.Tile.Trace.Body"]</p>
    </div>
</div>
