@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.ApplicationInsights.AspNetCore.JavaScriptSnippet JavaScriptSnippet
@inject IHtmlLocalizer<Mapaq.Web.SharedResource> L
@{
    var culture = CultureInfo.CurrentUICulture;
    var isFr = culture.TwoLetterISOLanguageName == "fr";
    var returnUrl = (Context.Request.Path + Context.Request.QueryString).ToString();
    string SetLang(string c) => $"/setlang?culture={c}&returnUrl={Uri.EscapeDataString(returnUrl)}";

    var path = Context.Request.Path.Value ?? "/";
    bool IsActive(string prefix) => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="@culture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · @L["Brand.Name"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* JS SDK Loader Script — picks up the connection string from server config so
       the raw value is never hard-coded in source. *@
    @Html.Raw(JavaScriptSnippet.FullScript)
    <script type="text/javascript" src="https://js.monitor.azure.com/scripts/b/ext/ai.clck.3.gbl.min.js"></script>
    <script type="text/javascript">
      (function () {
        if (window.appInsights && window.appInsights.config) {
          window.appInsights.config.enableAutoRouteTracking      = true;
          window.appInsights.config.enableCorsCorrelation        = true;
          window.appInsights.config.enableRequestHeaderTracking  = true;
          window.appInsights.config.enableResponseHeaderTracking = true;
          window.appInsights.config.distributedTracingMode = 2;
          window.appInsights.config.correlationHeaderExcludedDomains = [
            "*.queue.core.windows.net",
            "*.blob.core.windows.net",
            "login.microsoftonline.com",
            "graph.microsoft.com"
          ];
          window.appInsights.addTelemetryInitializer(function (envelope) {
            envelope.tags = envelope.tags || {};
            envelope.tags["ai.cloud.role"]         = "Mapaq.Browser";
            envelope.tags["ai.cloud.roleInstance"] = "browser";
          });
          if (typeof Microsoft !== "undefined" && Microsoft.ApplicationInsights) {
            var clickPlugin = new Microsoft.ApplicationInsights.ClickAnalyticsPlugin();
            window.appInsights.addPlugin(clickPlugin, false, function () {
              clickPlugin.processTelemetry = clickPlugin.processTelemetry.bind(clickPlugin);
            });
          }
        }
      })();
    </script>
</head>
<body>
    <header class="site-header">
        <div class="site-header__inner">
            <a class="brand" asp-page="/Index">
                <span class="brand__mark" aria-hidden="true">
                    <span></span><span></span><span></span><span></span>
                </span>
                <span class="brand__text">
                    <span>@L["Brand.Name"]</span>
                    <small>@L["Brand.Tagline"]</small>
                </span>
            </a>
            <div class="header-meta" role="group" aria-label="Language">
                <a href="@SetLang("fr-CA")" class="@(isFr ? "is-active" : "")">@L["Lang.French"]</a>
                <a href="@SetLang("en-CA")" class="@(isFr ? "" : "is-active")">@L["Lang.English"]</a>
            </div>
        </div>
    </header>

    <nav class="site-subnav" aria-label="@L["Nav.Home"]">
        <div class="site-subnav__inner">
            <a asp-page="/Index" class="@(path == "/" ? "is-active" : "")">@L["Nav.Home"]</a>
            <a asp-page="/Etablissements/Index" class="@(IsActive("/Etablissements") ? "is-active" : "")">@L["Nav.Establishments"]</a>
            <a asp-page="/Inspections/Rollup" class="@(IsActive("/Inspections") ? "is-active" : "")">@L["Nav.Rollup"]</a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <small>@L["Footer.Disclaimer"]</small>
    </footer>
</body>
</html>
