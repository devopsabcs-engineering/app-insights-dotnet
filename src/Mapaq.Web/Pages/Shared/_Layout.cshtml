@inject Microsoft.ApplicationInsights.AspNetCore.JavaScriptSnippet JavaScriptSnippet
@inject Microsoft.Extensions.Configuration.IConfiguration Cfg
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MAPAQ</title>

    @* JS SDK Loader Script — picks up the connection string from server config so
       the raw value is never hard-coded in source. The loader (sv:8) downloads
       @microsoft/applicationinsights-web v3.x from the Microsoft CDN. *@
    @Html.Raw(JavaScriptSnippet.FullScript)

    @* Distributed-tracing configuration overlay + Click Analytics plug-in *@
    <script type="text/javascript" src="https://js.monitor.azure.com/scripts/b/ext/ai.clck.3.gbl.min.js"></script>
    <script type="text/javascript">
      (function () {
        if (window.appInsights && window.appInsights.config) {
          window.appInsights.config.enableAutoRouteTracking      = true;
          window.appInsights.config.enableCorsCorrelation        = true;
          window.appInsights.config.enableRequestHeaderTracking  = true;
          window.appInsights.config.enableResponseHeaderTracking = true;
          // 2 = AI_AND_W3C (default in 3.x); set 1 for W3C-only.
          window.appInsights.config.distributedTracingMode = 2;
          window.appInsights.config.correlationHeaderExcludedDomains = [
            "*.queue.core.windows.net",
            "*.blob.core.windows.net",
            "login.microsoftonline.com",
            "graph.microsoft.com"
          ];

          // Cloud role: makes "Mapaq.Browser" appear as its own node on the map.
          window.appInsights.addTelemetryInitializer(function (envelope) {
            envelope.tags = envelope.tags || {};
            envelope.tags["ai.cloud.role"]         = "Mapaq.Browser";
            envelope.tags["ai.cloud.roleInstance"] = "browser";
          });

          // Click Analytics
          if (typeof Microsoft !== "undefined" && Microsoft.ApplicationInsights) {
            var clickPlugin = new Microsoft.ApplicationInsights.ClickAnalyticsPlugin();
            window.appInsights.addPlugin(clickPlugin, false, function () {
              clickPlugin.processTelemetry = clickPlugin.processTelemetry.bind(clickPlugin);
            });
          }
        }
      })();
    </script>
</head>
<body>
    <header>
        <nav>
            <a asp-page="/Index">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr" ? "Accueil" : "Home")</a> |
            <a asp-page="/Etablissements/Index">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr" ? "Établissements" : "Establishments")</a> |
            <a asp-page="/Inspections/Rollup">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr" ? "Tableau de bord régional" : "Regional dashboard")</a>
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
    <footer>
        <small>Application de démonstration. Non affiliée au gouvernement du Québec ni au MAPAQ. Données ouvertes utilisées sous licence Attribution (CC-BY 4.0).</small>
    </footer>
</body>
</html>
